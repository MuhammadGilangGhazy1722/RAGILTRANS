# ========== VITE + ENVIRONMENT ==========
# Set environment untuk Vite (development/production)
# Development = Dev server dengan HMR
# Production = Build untuk production
NODE_ENV=development

# ========== BACKEND API CONFIGURATION ==========
# Backend API URL
# Development (with proxy): Leave empty to use Vite proxy (/api → http://localhost:3000)
# Development (without proxy): http://localhost:3000
# Production: https://api.your-domain.com
VITE_API_URL=

# ========== STATIC FILES SERVER ==========
# Server URL untuk static files (images, uploads, etc)
# Development: http://localhost:3000
# Production: https://api.your-domain.com (same as backend)
VITE_SERVER_URL=http://localhost:3000

# ========== MIDTRANS PAYMENT GATEWAY ==========
# Midtrans Configuration untuk payment processing
# Get from: https://dashboard.sandbox.midtrans.com/ (Settings → Access Keys)
# Production: https://dashboard.midtrans.com/
# Sandbox client key starts with: SB-Mid-client-...
# Production client key starts with: Mid-client-...
#
VITE_MIDTRANS_CLIENT_KEY=SB-Mid-client-your-sandbox-key
VITE_MIDTRANS_PRODUCTION=false
