# Backend API URL
# Development: http://localhost:3001 or leave empty (uses Vite proxy)
# Production: https://api.your-domain.com
VITE_API_URL=

# Server URL for static files (images, uploads)
# Development: http://localhost:3000
# Production: https://api.your-domain.com (same as backend)
VITE_SERVER_URL=http://localhost:3000

# Midtrans Configuration
# Get from: https://dashboard.sandbox.midtrans.com/ (Settings -> Access Keys)
# Production: https://dashboard.midtrans.com/
# Sandbox client key starts with: SB-Mid-client-...
VITE_MIDTRANS_CLIENT_KEY=
VITE_MIDTRANS_PRODUCTION=false
