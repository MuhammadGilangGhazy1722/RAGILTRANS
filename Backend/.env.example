PORT=3000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=ragiltrans

JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS Origins - Comma separated list of allowed frontend URLs
# Development: http://localhost:5173
# Production: https://your-domain.com,https://www.your-domain.com
FRONTEND_URL=http://localhost:5173

# Backend URL (untuk OAuth callback)
BACKEND_URL=http://localhost:3000

# Midtrans Configuration
# Get from: https://dashboard.sandbox.midtrans.com/ (Sandbox) or https://dashboard.midtrans.com/ (Production)
# Sandbox keys start with: SB-Mid-server-... and SB-Mid-client-...
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# Google OAuth Configuration (Optional - untuk login dengan Google)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
